# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (tenant/API key metadata)
DATABASE_URL=postgresql://user:password@localhost:5432/ratelimitr

# Redis (rate limit counters — needs to be fast)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate limiter defaults (overridable per tenant)
DEFAULT_ALGORITHM=sliding_window   # token_bucket | sliding_window | fixed_window
DEFAULT_LIMIT=100
DEFAULT_WINDOW_MS=60000            # 1 minute
